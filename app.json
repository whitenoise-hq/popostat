{
  "expo": {
    "name": "포포스탯",
    "slug": "popostat",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "popostat",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.devwoodie.popostat",
      "buildNumber": "5",
      "usesAppleSignIn": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSPhotoLibraryUsageDescription": "반려동물 사진을 선택하여 전투력을 측정합니다.",
        "NSCameraUsageDescription": "반려동물 사진을 촬영하여 전투력을 측정합니다."
      }
    },
    "plugins": [
      "expo-router",
      "expo-image-picker",
      "expo-web-browser",
      "expo-splash-screen",
      "expo-sharing",
      "expo-font",
      "expo-apple-authentication"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "412aef5d-30fd-40dd-906f-4d9491afa86f"
      }
    },
    "owner": "devwoodie"
  }
}
